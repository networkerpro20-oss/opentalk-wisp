# Environment
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/opentalkwisp_dev?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# API
API_PREFIX="/api"
PORT=3000
CORS_ORIGIN="http://localhost:3001"

# Frontend
NEXT_PUBLIC_API_URL="http://localhost:3000"
NEXT_PUBLIC_WS_URL="ws://localhost:3000"

# OpenAI (optional for MVP)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4-turbo-preview"

# WhatsApp (Baileys)
WHATSAPP_SESSION_PATH="./baileys_sessions"

# Email (SendGrid)
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="noreply@opentalkwisp.local"
SENDGRID_FROM_NAME="OpenTalkWisp"

# AWS S3 (optional for MVP)
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_CDN_URL=""

# Monitoring (optional)
SENTRY_DSN=""
DATADOG_API_KEY=""
