// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-TENANCY & USERS
// ============================================

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  domain    String?  @unique // Para custom domains
  logo      String?
  plan      Plan     @default(FREE)
  status    OrgStatus @default(ACTIVE)
  
  // Configuración
  settings  Json?    // JSONB para configuración flexible
  
  // Límites según plan
  maxUsers      Int @default(1)
  maxContacts   Int @default(100)
  maxWhatsApps  Int @default(1)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relaciones
  users         User[]
  contacts      Contact[]
  conversations Conversation[]
  messages      Message[]
  deals         Deal[]
  pipelines     Pipeline[]
  tags          Tag[]
  templates     Template[]
  campaigns     Campaign[]
  flows         Flow[]
  whatsappInstances WhatsAppInstance[]
  teams         Team[]
  routingRules  RoutingRule[]
  quickReplies  QuickReply[]
  knowledgeBase KnowledgeBase?
  webhooks      Webhook[]
  apiKeys       ApiKey[]

  @@index([slug])
  @@index([domain])
  @@map("organizations")
}

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum OrgStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  password       String
  firstName      String
  lastName       String
  avatar         String?
  role           UserRole @default(AGENT)
  status         UserStatus @default(ACTIVE)
  
  // Multi-tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Timestamps
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  // Relaciones
  assignedConversations Conversation[]
  assignedDeals         Deal[]
  sentMessages          Message[]
  activities            Activity[]
  teamMemberships       TeamMember[]
  presence              UserPresence?
  routingRulesAssigned  RoutingRule[] @relation("RoutingRuleUser")
  quickRepliesCreated   QuickReply[]  @relation("QuickReplyCreator")
  internalNotesCreated  InternalNote[] @relation("InternalNoteAuthor")
  campaignsCreated      Campaign[]    @relation("CampaignCreator")
  
  @@index([organizationId])
  @@index([email])
  @@map("users")
}

enum UserRole {
  OWNER
  ADMIN
  AGENT
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
}

// ============================================
// CONTACTS & CRM
// ============================================

model Contact {
  id        String   @id @default(uuid())
  
  // Información básica
  name      String
  email     String?
  phone     String?
  avatar    String?
  
  // Información adicional
  company   String?
  position  String?
  notes     String?
  
  // Custom fields
  customFields Json?
  
  // Scoring IA
  score     Int @default(0) // 0-100
  
  // Multi-tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relaciones
  conversations Conversation[]
  deals         Deal[]
  tags          ContactTag[]
  activities    Activity[]
  campaignExecutions CampaignExecution[]
  
  @@index([organizationId])
  @@index([phone])
  @@index([email])
  @@map("contacts")
}

// ============================================
// WHATSAPP & MESSAGES
// ============================================

model WhatsAppInstance {
  id        String   @id @default(uuid())
  
  // Configuración
  name      String
  phone     String?
  status    WhatsAppStatus @default(DISCONNECTED)
  qrCode    String?
  
  // Session data (Baileys)
  sessionData Json?
  
  // Multi-tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Timestamps
  connectedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // AI Auto-Responder
  aiAutoRespond Boolean @default(false)

  // Relaciones
  conversations Conversation[]
  messages      Message[]

  @@index([organizationId])
  @@map("whatsapp_instances")
}

enum WhatsAppStatus {
  CONNECTED
  DISCONNECTED
  QR_CODE
  ERROR
}

model Conversation {
  id        String   @id @default(uuid())
  
  // Estado
  status    ConversationStatus @default(OPEN)
  channel   Channel @default(WHATSAPP)
  
  // Asignación
  assignedToId String?
  assignedTo   User? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToTeamId String?
  assignedToTeam   Team? @relation("TeamConversations", fields: [assignedToTeamId], references: [id], onDelete: SetNull)
  
  // WhatsApp
  whatsappInstanceId String?
  whatsappInstance   WhatsAppInstance? @relation(fields: [whatsappInstanceId], references: [id], onDelete: SetNull)
  
  // Contact
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  // Analisis IA
  sentiment String? // positive, negative, neutral
  summary   String?
  aiHandled Boolean @default(false)
  aiTakenOverAt DateTime?
  aiTakenOverById String?
  
  // Multi-tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Timestamps
  lastMessageAt DateTime @default(now())
  closedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relaciones
  messages Message[]
  internalNotes InternalNote[]
  tags ConversationTag[]
  
  @@index([organizationId])
  @@index([contactId])
  @@index([assignedToId])
  @@index([status])
  @@map("conversations")
}

enum ConversationStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum Channel {
  WHATSAPP
  EMAIL
  WEBCHAT
}

model Message {
  id        String   @id @default(uuid())
  
  // Contenido
  content   String
  type      MessageType @default(TEXT)
  mediaUrl  String?
  
  // Dirección
  direction MessageDirection
  
  // Estado
  status    MessageStatus @default(SENT)
  
  // Relaciones principales
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  contactId String
  
  whatsappInstanceId String?
  whatsappInstance   WhatsAppInstance? @relation(fields: [whatsappInstanceId], references: [id], onDelete: SetNull)
  
  sentById  String?
  sentBy    User? @relation(fields: [sentById], references: [id], onDelete: SetNull)
  
  // WhatsApp specific
  whatsappMessageId String?
  
  // Multi-tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Timestamps
  sentAt    DateTime @default(now())
  readAt    DateTime?
  createdAt DateTime @default(now())
  
  @@index([organizationId])
  @@index([conversationId])
  @@index([whatsappMessageId])
  @@map("messages")
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  LOCATION
  CONTACT
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

// ============================================
// CRM - DEALS & PIPELINES
// ============================================

model Pipeline {
  id        String   @id @default(uuid())
  
  name      String
  order     Int @default(0)
  
  // Multi-tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relaciones
  stages    Stage[]
  deals     Deal[]
  
  @@index([organizationId])
  @@map("pipelines")
}

model Stage {
  id        String   @id @default(uuid())
  
  name      String
  order     Int
  color     String?
  
  // Pipeline
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relaciones
  deals     Deal[]
  
  @@index([pipelineId])
  @@map("stages")
}

model Deal {
  id        String   @id @default(uuid())
  
  // Información básica
  title       String
  description String?
  value       Decimal @db.Decimal(10, 2)
  currency    String @default("USD")
  
  // Estado
  status    DealStatus @default(OPEN)
  probability Int @default(50) // 0-100
  
  // Fechas importantes
  expectedCloseDate DateTime?
  closedDate        DateTime?
  
  // Relaciones
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  stageId   String
  stage     Stage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  
  assignedToId String?
  assignedTo   User? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  
  // Multi-tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relaciones
  activities Activity[]
  
  @@index([organizationId])
  @@index([contactId])
  @@index([stageId])
  @@index([status])
  @@map("deals")
}

enum DealStatus {
  OPEN
  WON
  LOST
}

// ============================================
// TAGS & ACTIVITIES
// ============================================

model Tag {
  id        String   @id @default(uuid())
  
  name      String
  color     String
  
  // Multi-tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt DateTime @default(now())
  
  // Relaciones
  contacts  ContactTag[]
  conversations ConversationTag[]
  
  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("tags")
}

model ContactTag {
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  tagId     String
  tag       Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@id([contactId, tagId])
  @@map("contact_tags")
}

model ConversationTag {
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  tagId     String
  tag       Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  
  @@id([conversationId, tagId])
  @@map("conversation_tags")
}

model Activity {
  id        String   @id @default(uuid())
  
  type      ActivityType
  title     String
  description String?
  
  // Relaciones
  contactId String?
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  dealId    String?
  deal      Deal? @relation(fields: [dealId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt DateTime @default(now())
  
  @@index([contactId])
  @@index([dealId])
  @@index([userId])
  @@map("activities")
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
  TASK
}

// ============================================
// AUTOMATION - CAMPAIGNS & FLOWS
// ============================================

model Template {
  id        String   @id @default(uuid())
  
  name      String
  content   String
  type      TemplateType @default(TEXT)
  
  // Multi-tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([organizationId])
  @@map("templates")
}

enum TemplateType {
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
}

model Campaign {
  id        String   @id @default(uuid())
  
  name      String
  description String?
  status    CampaignStatus @default(DRAFT)
  
  // Configuracion
  targetSegment   Json?        // Criterios de segmentacion
  messageTemplate String
  mediaUrl        String?

  // AI Campaign features
  aiBrief         String?      // Brief para que IA genere mensaje
  aiGeneratedText String?      // Texto generado por IA
  campaignMessageType String   @default("TEXT") // TEXT, AUDIO, IMAGE, DOCUMENT
  audioUrl        String?      // URL de audio TTS generado
  ttsVoice        String?      @default("alloy") // OpenAI TTS voice
  variants        Json?        // A/B testing: [{id, message, weight}]

  // Programacion
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  messagesPerMinute Int       @default(10)
  autoStart       Boolean     @default(false)
  
  // Multi-tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Creator
  createdById    String
  createdBy      User         @relation("CampaignCreator", fields: [createdById], references: [id], onDelete: Cascade)
  
  // Relaciones
  executions     CampaignExecution[]
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([organizationId])
  @@index([status])
  @@map("campaigns")
}

model CampaignExecution {
  id         String   @id @default(uuid())
  campaignId String
  contactId  String
  
  status     ExecutionStatus @default(PENDING)
  sentAt     DateTime?
  deliveredAt DateTime?
  readAt     DateTime?
  repliedAt  DateTime?
  error      String?
  variantId  String?         // A/B variant sent
  responseContent String?    // Contact's response content

  // Relaciones
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  @@index([campaignId])
  @@index([contactId])
  @@index([status])
  @@map("campaign_executions")
}

enum ExecutionStatus {
  PENDING
  SENT
  DELIVERED
  READ
  REPLIED
  FAILED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  PAUSED
  CANCELLED
}

model Flow {
  id        String   @id @default(uuid())
  
  name      String
  trigger   FlowTrigger
  status    FlowStatus @default(INACTIVE)
  
  // Configuración del flujo (JSON)
  config    Json?
  
  // Multi-tenancy
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([organizationId])
  @@map("flows")
}

enum FlowTrigger {
  NEW_CONTACT
  NEW_MESSAGE
  TAG_ADDED
  DEAL_STAGE_CHANGE
}

enum FlowStatus {
  ACTIVE
  INACTIVE
}

// ============================================
// FASE 1: TEAMS & ROUTING
// ============================================

model Team {
  id              String   @id @default(uuid())
  name            String
  description     String?
  isActive        Boolean  @default(true)
  
  // Configuración
  maxConcurrentChats  Int  @default(10)
  workingHours        Json? // { monday: {start: "09:00", end: "18:00"}, ... }
  
  // Multi-tenancy
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Relaciones
  members         TeamMember[]
  conversations   Conversation[] @relation("TeamConversations")
  routingRules    RoutingRule[]
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([organizationId])
  @@index([isActive])
  @@map("teams")
}

model TeamMember {
  id        String   @id @default(uuid())
  teamId    String
  userId    String
  role      TeamRole @default(AGENT)
  isActive  Boolean  @default(true)
  
  // Configuración individual
  maxConcurrentChats Int @default(5)
  
  // Relaciones
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@map("team_members")
}

enum TeamRole {
  ADMIN
  SUPERVISOR
  AGENT
}

model RoutingRule {
  id              String   @id @default(uuid())
  name            String
  description     String?
  priority        Int      @default(0)
  isActive        Boolean  @default(true)
  
  // Condiciones (JSON)
  conditions      Json     // { channel: "WHATSAPP", tags: [], keywords: [], hours: {} }
  
  // Acciones
  assignmentType  AssignmentType @default(ROUND_ROBIN)
  assignToUserId  String?
  assignToTeamId  String?
  
  // Multi-tenancy
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Relaciones
  assignToUser    User?    @relation("RoutingRuleUser", fields: [assignToUserId], references: [id], onDelete: SetNull)
  assignToTeam    Team?    @relation(fields: [assignToTeamId], references: [id], onDelete: SetNull)
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([organizationId])
  @@index([isActive])
  @@index([priority])
  @@map("routing_rules")
}

enum AssignmentType {
  ROUND_ROBIN
  LEAST_BUSY
  SPECIFIC_USER
  SPECIFIC_TEAM
  LOAD_BALANCED
}

model UserPresence {
  id              String        @id @default(uuid())
  userId          String        @unique
  status          PresenceStatus @default(OFFLINE)
  customMessage   String?
  
  // Capacidad
  maxConcurrentChats  Int       @default(5)
  currentChats        Int       @default(0)
  
  // Horario y disponibilidad
  workingHours    Json?         // { monday: {start: "09:00", end: "18:00"}, ... }
  isOnBreak       Boolean       @default(false)
  breakEndsAt     DateTime?
  
  // Relaciones
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Timestamps
  lastSeenAt      DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  @@index([userId])
  @@index([status])
  @@map("user_presence")
}

enum PresenceStatus {
  ONLINE
  BUSY
  AWAY
  OFFLINE
}

// ============================================
// FASE 2: PRODUCTIVITY
// ============================================

model QuickReply {
  id              String   @id @default(uuid())
  shortcut        String   // /gracias, /horario
  title           String
  content         String   // "Hola {{nombre}}, gracias por contactarnos"
  description     String?
  category        String?  // "Saludos", "Despedidas", "Precios"
  tags            String[] @default([])
  
  isActive        Boolean  @default(true)
  isShared        Boolean  @default(true)
  useCount        Int      @default(0)
  
  // Multi-tenancy
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  createdById     String
  createdBy       User         @relation("QuickReplyCreator", fields: [createdById], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([organizationId, shortcut])
  @@index([organizationId])
  @@index([category])
  @@map("quick_replies")
}

model InternalNote {
  id              String   @id @default(uuid())
  conversationId  String
  content         String
  mentions        String[] // IDs de usuarios mencionados
  
  // Relaciones
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  createdById     String
  createdBy       User         @relation("InternalNoteAuthor", fields: [createdById], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([conversationId])
  @@index([createdById])
  @@map("internal_notes")
}

// ============================================
// AI KNOWLEDGE BASE
// ============================================

model KnowledgeBase {
  id                  String   @id @default(uuid())
  name                String   @default("Base de Conocimiento")
  description         String?
  isActive            Boolean  @default(true)

  // AI Agent Configuration
  systemPrompt        String?
  personality         Personality @default(PROFESSIONAL)
  confidenceThreshold Float   @default(0.7)
  autoResponseEnabled Boolean @default(false)
  customApiKey        String?

  // Business hours
  businessHours       Json?
  outsideHoursMessage String?

  // Multi-tenancy (one KB per org)
  organizationId      String   @unique
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relations
  items               KnowledgeItem[]

  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([organizationId])
  @@map("knowledge_bases")
}

enum Personality {
  PROFESSIONAL
  FRIENDLY
  AGGRESSIVE
  EDUCATIONAL
}

model KnowledgeItem {
  id              String   @id @default(uuid())

  title           String
  content         String
  category        String?
  priority        Int      @default(5)

  // Source tracking
  sourceType      KBSourceType
  sourceUrl       String?
  sourceFileName  String?

  // Search
  keywords        String[] @default([])
  embedding       Json?

  isActive        Boolean  @default(true)

  // Relations
  knowledgeBaseId String
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([knowledgeBaseId])
  @@index([category])
  @@index([isActive])
  @@map("knowledge_items")
}

enum KBSourceType {
  URL
  DOCUMENT
  WIZARD
  MANUAL
}

// ============================================
// WEBHOOKS & API KEYS (Phase 3)
// ============================================

model Webhook {
  id          String   @id @default(uuid())
  name        String
  url         String
  secret      String?  // HMAC secret for signature verification
  events      String[] // e.g. ["contact.created", "message.received"]
  isActive    Boolean  @default(true)
  maxRetries  Int      @default(3)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  logs        WebhookLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId])
  @@index([isActive])
  @@map("webhooks")
}

model WebhookLog {
  id          String   @id @default(uuid())
  webhookId   String
  event       String
  payload     Json
  statusCode  Int?
  responseBody String?
  attempt     Int      @default(1)
  success     Boolean  @default(false)
  error       String?

  webhook     Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([webhookId])
  @@index([createdAt])
  @@map("webhook_logs")
}

model ApiKey {
  id          String   @id @default(uuid())
  name        String
  keyHash     String   @unique  // Hashed API key
  prefix      String   // First 8 chars for identification (e.g. "otw_xxxx")
  permissions String[] // e.g. ["contacts.read", "contacts.write", "messages.read"]
  isActive    Boolean  @default(true)
  rateLimit   Int      @default(100) // requests per minute
  lastUsedAt  DateTime?
  expiresAt   DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([organizationId])
  @@index([prefix])
  @@map("api_keys")
}

// ============================================
// AI AUTO-RESPONDER FEEDBACK (Phase 4)
// ============================================

model AiResponseFeedback {
  id          String   @id @default(uuid())
  messageId   String
  aiResponse  String
  agentResponse String?
  wasUsed     Boolean  @default(false)
  rating      Int?     // 1-5

  organizationId String

  createdAt   DateTime @default(now())

  @@index([organizationId])
  @@index([messageId])
  @@map("ai_response_feedback")
}
