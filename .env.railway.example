# ====================================================
# RAILWAY ENVIRONMENT VARIABLES - OpenTalkWisp Backend
# ====================================================
# Copia estas variables en Railway Dashboard → Variables

# ============================================
# RAILWAY AUTO-GENERATED (No necesitas configurarlas manualmente)
# ============================================
DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=${{Redis.REDIS_URL}}
REDIS_HOST=${{Redis.REDIS_HOST}}
REDIS_PORT=${{Redis.REDIS_PORT}}

# ============================================
# RAILWAY ENVIRONMENT DETECTION
# ============================================
RAILWAY_ENVIRONMENT=production
NODE_ENV=production
PORT=3000

# ============================================
# JWT CONFIGURATION (¡CAMBIAR EN PRODUCCIÓN!)
# ============================================
JWT_SECRET=tu-jwt-secret-super-seguro-cambiar-en-produccion
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# API CONFIGURATION
# ============================================
API_PREFIX=/api

# ============================================
# CORS & FRONTEND URL
# ============================================
# Reemplaza con tu URL de Vercel
FRONTEND_URL=https://opentalk-wisp-frontend.vercel.app
CORS_ORIGIN=https://opentalk-wisp-frontend.vercel.app

# ============================================
# OPENAI (OPCIONAL - Para funciones de IA)
# ============================================
OPENAI_API_KEY=sk-tu-api-key-aqui
OPENAI_MODEL=gpt-4-turbo-preview

# ============================================
# AWS S3 (OPCIONAL - Para almacenamiento de medios)
# ============================================
AWS_REGION=us-east-1
AWS_S3_BUCKET=opentalk-wisp-media
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_CDN_URL=

# ============================================
# EMAIL (OPCIONAL - Para notificaciones)
# ============================================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@opentalkwisp.com
SENDGRID_FROM_NAME=OpenTalkWisp

# ============================================
# MONITORING (OPCIONAL)
# ============================================
SENTRY_DSN=
DATADOG_API_KEY=

# ============================================
# NOTAS IMPORTANTES:
# ============================================
# 1. Las variables con ${{}} son auto-generadas por Railway
# 2. RAILWAY_ENVIRONMENT debe estar en "production" para usar el volumen persistente
# 3. El volumen debe estar montado en: /app/wa-sessions
# 4. JWT_SECRET DEBE ser cambiado en producción por seguridad
# 5. FRONTEND_URL debe apuntar a tu deployment de Vercel
